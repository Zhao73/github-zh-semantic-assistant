{
  "manifest_version": 3,
  "name": "GitHub 中文语义助手",
  "version": "0.1.1",
  "description": "把 GitHub 的界面、仓库介绍、README、Issue 和 PR 内容翻译成准确的中文技术语义。",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "GitHub 中文语义助手",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "commands": {
    "toggle-extension": {
      "suggested_key": {
        "default": "Alt+Shift+G",
        "mac": "Alt+Shift+G"
      },
      "description": "开启或关闭 GitHub 中文语义助手"
    },
    "translate-page": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "mac": "Alt+Shift+T"
      },
      "description": "立即翻译当前 GitHub 页面"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "css": [
        "styles/content.css"
      ],
      "js": [
        "src/defaults.js",
        "src/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
